rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && userRole() == "admin";
    }

    function isImportUser() {
      return signedIn() && userRole() == "import";
    }

    function isExportUser() {
      return signedIn() && userRole() == "export";
    }

    // Users roles
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Imports
    match /imports/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isImportUser();
    }

    // Exports
    match /exports/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isExportUser();
    }

    // History
    match /history/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }
  }
}